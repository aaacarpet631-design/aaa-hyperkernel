rules_version = '2';

// AAA HyperKernel — Firestore security rules.
// All app data lives under workspaces/{ws}/**. Only signed-in users who have a
// membership doc (workspaces/{ws}/members/{uid}) can read or write that
// workspace's data. This is the Firestore equivalent of the Supabase RLS.
service cloud.firestore {
  match /databases/{database}/documents {

    function memberDoc(ws) {
      return get(/databases/$(database)/documents/workspaces/$(ws)/members/$(request.auth.uid));
    }
    function isMember(ws) {
      return request.auth != null
        && exists(/databases/$(database)/documents/workspaces/$(ws)/members/$(request.auth.uid));
    }
    // Members without an explicit role are treated as 'crew' (least privilege).
    function role(ws) {
      return isMember(ws) ? (('role' in memberDoc(ws).data) ? memberDoc(ws).data.role : 'crew') : 'none';
    }
    function isOwner(ws) { return role(ws) == 'owner'; }

    // Collections that expose money internals — owner-only, enforced server-side
    // so a tampered or crew client still cannot read them.
    function isFinancialCollection(c) {
      return c == 'accounting' || c == 'invoices' || c == 'payments'
          || c == 'expenses' || c == 'kpi_snapshots' || c == 'rate_cards'
          // Receipt intake + the expense classifier's learning/accuracy stores
          // all expose spend internals — owner-only, same as the rest of the books.
          || c == 'receipts' || c == 'expense_corrections' || c == 'expense_predictions'
          // Quote lifecycle records carry internal cost + margin + job cost.
          || c == 'quotes'
          // Pricing optimizer recommendations expose margin/win-rate analysis.
          || c == 'pricing_recommendations'
          // Prediction-closure / learning-feedback records expose win-rate/margin.
          || c == 'learning_feedback'
          // Calibration proposals + versions govern AI tuning from spend data.
          || c == 'calibration_proposals' || c == 'calibration_versions'
          // Supervisor Council sessions expose margin/finance deliberation.
          || c == 'council_sessions'
          // Provenance traces expose the quotes/margins/win-rates behind a
          // recommendation — owner-only, same as the rest of the analysis.
          || c == 'provenance'
          // Governance Registry: versioned prompts/models/templates/policies/
          // calibrations + approval workflow — owner-only (governs the AI org).
          || c == 'governance_versions'
          // Replay Sandbox snapshots replay margins/win-rates/decisions under
          // alternative governed versions — owner-only, same as the analysis.
          || c == 'replay_snapshots'
          // Native event-bus log — immutable domain events that can carry
          // business data (quotes/jobs/messages); owner-only.
          || c == 'event_log'
          // Privacy & data governance: vault key + retention config, the
          // encrypted PII vault, and erasure requests — owner-only (the vault
          // protects the most sensitive PII).
          || c == 'privacy_config' || c == 'privacy_vault' || c == 'deletion_requests'
          // Reliability Command Center: metric snapshots + incidents aggregate
          // conversion/margin-derived KPIs — owner-only, same as the analysis.
          || c == 'reliability_snapshots' || c == 'incidents'
          // Outcome Intelligence: outcome events, agent scores/accuracy, and
          // learning patterns expose margins + win rates — owner-only.
          || c == 'outcome_events' || c == 'agent_scores' || c == 'agent_accuracy' || c == 'learning_patterns'
          // Executive Council reviews high-impact money decisions — owner-only.
          || c == 'executive_reviews'
          // Learning Fabric job memory exposes margins + win rates — owner-only.
          || c == 'job_memory'
          // Business Digital Twin saved scenarios model revenue/margin — owner-only.
          || c == 'twin_scenarios'
          // Financial Intelligence snapshots expose the books — owner-only.
          || c == 'financial_snapshots'
          // Governed Learning Loop proposals carry margins/win-rates — owner-only.
          || c == 'proposals'
          // Agent Evaluation Lab snapshots expose performance/ROI — owner-only.
          || c == 'agent_evaluations'
          // Knowledge OS index + query log aggregate everything — owner-only.
          || c == 'knowledge_nodes' || c == 'knowledge_queries'
          // Vector/semantic memory embeds the knowledge corpus — owner-only.
          || c == 'memory_vectors'
          // Owner Copilot daily briefings aggregate the whole business — owner-only.
          || c == 'owner_briefings'
          // Native Model candidates carry trained weights + metrics — owner-only.
          || c == 'model_versions'
          // NVIDIA Model Adapter Layer: enablement settings + model-call usage/
          // provenance stream — owner-only (governs external intelligence engines).
          || c == 'model_settings' || c == 'model_calls'
          // Google Ads governance: the conversion ladder + released export
          // batches carry realized revenue values, and recommendations carry
          // spend/impact payloads — owner-only, same as the rest of the books.
          // (ad_attribution itself stays member-writable: lead intake attaches
          // click context and it holds no money and no PII.)
          || c == 'ads_conversion_events' || c == 'ads_conversion_exports'
          || c == 'ads_recommendations';
    }
    // Collections only a trusted backend (Admin SDK) may touch. Notably
    // 'integrations' holds QuickBooks OAuth tokens — clients must never read it.
    function isServerOnlyCollection(c) {
      return c == 'integrations';
    }
    // Collections that have their OWN dedicated match block below and must NOT
    // also be granted by the generic wildcard. Firestore allows a request if
    // ANY matching rule allows it, so without this guard the wildcard would
    // silently override the stricter rules for members + audit_log (any member
    // could read/edit/delete the audit_log and write member docs).
    function isSpecialCollection(c) {
      return c == 'members' || c == 'audit_log'
          || c == 'governance_audit' || c == 'gov_prompt_registry'
          || isServerOnlyCollection(c);
    }
    // Legal records carry sensitive legal / incident detail — restricted to the
    // legal roles. Owner + manager hold VIEW_LEGAL/MANAGE_LEGAL; crew cannot read
    // or write them (mirrors the Legal War Room's client-side gate, enforced
    // server-side so a tampered/crew client still can't reach legal records).
    function isLegalCollection(c) {
      return c == 'legal_records';
    }
    function canLegal(ws) { return role(ws) == 'owner' || role(ws) == 'manager'; }
    // Native Transport conversations: customer threads, inbound replies, and
    // owner notifications. Office-only (owner + manager hold EDIT_CUSTOMER);
    // crew never sees customer conversations — enforced server-side to mirror
    // the inbox's client-side gate.
    function isCommsCollection(c) {
      return c == 'comm_threads' || c == 'comm_inbound' || c == 'comm_notifications'
          // AI-drafted customer messages awaiting owner approval — office-only.
          || c == 'assisted_drafts'
          // Sensed real-world signals carry customer contact + message content.
          || c == 'sensed_events';
    }
    function canComms(ws) { return role(ws) == 'owner' || role(ws) == 'manager'; }
    // Security hardening: step-up/MFA secrets, signing key, and signed sessions.
    // Owner-only (these hold the secrets that protect privileged actions); in a
    // multi-tenant deployment these belong server-side entirely.
    function isSecurityCollection(c) {
      return c == 'security_config' || c == 'security_sessions';
    }

    match /workspaces/{ws} {
      allow read: if isMember(ws);
      allow write: if false;

      match /members/{uid} {
        allow read: if isMember(ws);
        allow write: if false; // manage members from the console / a trusted backend
      }

      // Audit log: any member may append; nobody may edit/delete (tamper-proof);
      // only the owner may read the full trail.
      match /audit_log/{docId} {
        allow create: if isMember(ws);
        allow read: if isOwner(ws);
        allow update, delete: if false;
      }

      // Governance immutable ledger: any member may append; nobody may edit or
      // delete (tamper-proof, server-enforced); only the owner reads the trail.
      match /governance_audit/{docId} {
        allow create: if isMember(ws);
        allow read: if isOwner(ws);
        allow update, delete: if false;
      }

      // Governed prompt registry drives live agent behavior — any member reads
      // (runtime prompt resolution), only the owner writes (apply/rollback/promote).
      match /gov_prompt_registry/{docId} {
        allow read: if isMember(ws);
        allow write: if isOwner(ws);
      }

      // All other workspace-scoped collections. Financial collections are
      // owner-only; everything else is any member.
      match /{collection}/{docId} {
        allow read, write: if isMember(ws) && !isSpecialCollection(collection)
          && (!isFinancialCollection(collection) || isOwner(ws))
          && (!isLegalCollection(collection) || canLegal(ws))
          && (!isCommsCollection(collection) || canComms(ws))
          && (!isSecurityCollection(collection) || isOwner(ws));
      }
      match /{collection}/{docId}/{sub=**} {
        allow read, write: if isMember(ws) && !isSpecialCollection(collection)
          && (!isFinancialCollection(collection) || isOwner(ws))
          && (!isLegalCollection(collection) || canLegal(ws))
          && (!isCommsCollection(collection) || canComms(ws))
          && (!isSecurityCollection(collection) || isOwner(ws));
      }
    }
  }
}
