{"nodes": [{"id": "setup_brev_private_gpu_provider", "label": "Governed Private GPU Model Provider (P24)", "file_type": "concept", "source_file": "SETUP-BREV.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The app never sees the GPU URL or key \u2014 it POSTs to a same-origin proxy that holds PRIVATE_GPU_MODEL_URL/KEY; port 8000 is not public and must be locked to the backend egress IP (the API key is defense in depth, not the perimeter). With nothing configured the proxy returns GPU_NOT_CONFIGURED and the app falls back rather than fabricating output; the model is off by default and owner-enabled via Model Governance."}], "edges": [{"source": "functions_private_gpu", "target": "setup_brev_private_gpu_provider", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BREV.md", "source_location": null, "weight": 1.0}, {"source": "providers_private_gpu_transport_aaa_private_gpu_transport", "target": "setup_brev_private_gpu_provider", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BREV.md", "source_location": null, "weight": 1.0}, {"source": "providers_private_gpu_transport_aaa_private_gpu_transport", "target": "functions_private_gpu", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BREV.md", "source_location": null, "weight": 1.0}, {"source": "hyperkernel_honest_by_construction", "target": "setup_brev_private_gpu_provider", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "SETUP-BREV.md", "source_location": null, "weight": 1.0}], "hyperedges": []}