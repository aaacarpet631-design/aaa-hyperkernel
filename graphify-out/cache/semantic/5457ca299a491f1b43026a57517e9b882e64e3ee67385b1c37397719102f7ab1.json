{"nodes": [{"id": "setup_bluetooth_measurement_bluetooth_layer", "label": "Bluetooth Laser Measurement Layer", "file_type": "concept", "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Implemented with the Web Bluetooth API because the app is a vanilla-JS PWA, not React Native/Expo; iOS does not support Web Bluetooth so the app detects this and routes to manual entry. Safety guarantees by design: never blocks a quote, never finalizes price (everything is needsReview), never loses field data (local save before network), never fabricates (unparseable readings return null), workspace-isolated."}, {"id": "setup_bluetooth_measurement_huepar_provisional_protocol", "label": "Huepar S60 Provisional Protocol (experimental/huepar-s60-v1)", "file_type": "rationale", "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The GATT contract comes from public reverse-engineering of the LDM-S60-BT, not vendor certification, so it is deliberately marked experimental and must be lab-validated before being trusted for money-bearing measurements. Metres are canonical; implausible decodes are rejected rather than guessed; an in-band quality flag drops confidence so low-trust reads land in review; angle/tilt frames are diagnostics only; the checksum is recorded but never gated on because the algorithm is unverified."}], "edges": [{"source": "services_huepar_s60_adapter_aaa_huepar_s60_adapter", "target": "services_generic_ble_adapter_genericblemeasurementadapter", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "services_huepar_s60_adapter_aaa_huepar_s60_adapter", "target": "services_device_adapter_registry_deviceadapterregistry", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "services_huepar_s60_adapter_aaa_huepar_s60_adapter", "target": "services_raw_reading_log_rawbluetoothreadinglog", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "setup_bluetooth_measurement_huepar_provisional_protocol", "target": "services_huepar_s60_adapter_aaa_huepar_s60_adapter", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "hooks_use_bluetooth_connection_aaa_bluetooth", "target": "services_huepar_s60_adapter_aaa_huepar_s60_adapter", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "hooks_use_bluetooth_connection_aaa_bluetooth", "target": "services_device_adapter_registry_deviceadapterregistry", "relation": "calls", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "services_generic_ble_adapter_genericblemeasurementadapter", "target": "services_measurement_parser_measurementparser", "relation": "shares_data_with", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "integrations_measurement_to_quote", "target": "storage_measurement_store", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-BLUETOOTH-MEASUREMENT.md", "source_location": null, "weight": 1.0}, {"source": "hyperkernel_honest_by_construction", "target": "measurements_measurement_ai_assistant