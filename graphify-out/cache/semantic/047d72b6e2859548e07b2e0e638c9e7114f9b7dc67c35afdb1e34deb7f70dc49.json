{"nodes": [{"id": "setup_nemotron_nemotron_provider", "label": "NVIDIA Nemotron Provider (hosted, OpenAI-compatible)", "file_type": "concept", "source_file": "SETUP-NEMOTRON.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Nemotron-3-Nano-Omni-30B is a 30B model needing a GPU host, so NVIDIA's hosted endpoint is used instead of local serving to keep the app a PWA + serverless deploy; switching provider is a config flip (aiProvider:'nemotron') with no agent code changes because the translate layer maps agent-pinned Claude model ids to the Nemotron model."}, {"id": "setup_nemotron_fail_closed_review_safety", "label": "Fail-Closed Review-Safety Verdict Mapping", "file_type": "rationale", "source_file": "SETUP-NEMOTRON.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only a clean 'safe' verdict allows a normal send; 'unsafe' blocks, and unknown/unreadable/proxy-error/guardrail-unavailable all queue for human review rather than defaulting to safe. The guardrail only classifies \u2014 it never blocks, edits, sends or stores; 'safe' is null (unknown) rather than a false 'safe' when a reply cannot be read, so callers can fail closed. Scoped intentionally to AI-drafted review texts; the human-authored template fallback is not screened."}], "edges": [{"source": "setup_nemotron_nemotron_provider", "target": "functions_nemotron_translate", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SETUP-NEMOTRON.md", "source_location": null, "weight": 1.0}, {"source": "functions_nemotron_translate", "target": "functions_claude_proxy", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "SETUP-NEMOTRON.md", "source_location": null, "weight": 1.0}, {"source": "ai_content_safety_aaa_content_safety", "target": "setup_nemotron_nemotron_provider", "rela