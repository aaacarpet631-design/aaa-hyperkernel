{"nodes": [{"id": "governance_fail_closed_override", "label": "Fail-Closed Override Policy", "file_type": "rationale", "source_file": "GOVERNANCE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only an explicit Admin (RBAC OVERRIDE_AI_DECISION, owner-only) override with a >=20-char written justification can unlock a held case; the gate uses RBAC authority, not a client-supplied role, so it cannot be spoofed; an override only unlocks the Send button and never auto-resends \u2014 recordSent() is a separate, explicitly-human, separately-audited action."}, {"id": "governance_hash_chained_audit", "label": "Hash-Chained Immutable Audit Trail", "file_type": "concept", "source_file": "GOVERNANCE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Append-only, deep-frozen, FNV-1a + SHA-256 chained, optionally HMAC-signed entries make tampering detectable at the exact index; multi-writer lanes keyed by writerId let concurrent devices append without collisions while keeping each lane independently verifiable."}, {"id": "governance_drift_detection", "label": "Override Drift Detection (pattern alerts)", "file_type": "concept", "source_file": "GOVERNANCE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Repeated overrides of the same category beyond PATTERN_THRESHOLD signal model drift or an overly aggressive classifier; threshold windowing plus cooldown ensures escalation fires only on a crossing, never on every override, so the owner is alerted without spam."}], "edges": [{"source": "governance_governance_engine_aaa_governance_engine", "target": "governance_governance_escalation_aaa_governance_escalation", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GOVERNANCE.md", "source_location": null, "weight": 1.0}, {"source": "gove